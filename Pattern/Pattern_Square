public class Pattern_Square {

    public static void patternSquare(int n){
        for(int i=1;i<=n;i++){
            for(int j=1;j<=n;j++){
                if(i%2!=0){
                    System.out.print((char)(96+i));
                } else {
                    System.out.print((char)(64+i));
                }
            }
            System.out.println();
        }
    }

    public static void main(String[] args) {
        patternSquare(5);
    }
}
