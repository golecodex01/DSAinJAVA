public class Pattern_Diamond {

    public static void printDiamond(int n){
        int upperspace=n-1;
        int upperstar=1;

        for(int i=1;i<=n;i++){
            for(int j=1;j<=upperspace;j++){
                System.out.print(" ");
            }
            for(int j=1;j<=upperstar;j++){
                System.out.print("*");
            }
            upperspace--;
            upperstar+=2;
            System.out.println();
        }

        int lowerSpace=1;
        int lowerStar=(2*n)-3;

        for(int i=1;i<=n;i++){
            for(int j=1;j<=lowerSpace;j++){
                System.out.print(" ");
            }
            for(int j=1;j<=lowerStar;j++){
                System.out.print("*");
            }
            lowerSpace++;
            lowerStar-=2;
            System.out.println();
        }
    }

    public static void main(String[] args) {
        printDiamond(5);
    }
}
