class Solution {
    public ArrayList<Integer> intersection(int arr1[], int arr2[]) {
      
        
        ArrayList<Integer> result=new  ArrayList<>();
        int n=arr1.length;
        int m=arr2.length;
        int i=0;
        int j=0;
        
        while(i<n && j<m){
            if(arr1[i]>arr2[j]){
                j++;
            }
            else if(arr1[i]<arr2[j]){
                i++;
            }
            else{
                if(result.isEmpty() || result.get(result.size()-1)!=arr1[i]){
                    result.add(arr1[i]);
            
                    }
                i++;
                j++;
            }
        }
      return result ;  
    }
}
