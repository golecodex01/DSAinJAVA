class Solution {
    public int numOfSubarrays(int[] arr, int k, int threshold) {
        
     int windowSum=0;
     int count =0;
     double avg ;
     for(int i=0;i<k;i++){
        windowSum=windowSum+arr[i];
        
     }
        avg=windowSum/k;
        if(avg>=threshold){
        count++;
        }
    
     for(int i=k;i<arr.length;i++){
        windowSum=windowSum+arr[i];
        windowSum=windowSum-arr[i-k];
            avg=windowSum/k;
        if(avg>=threshold){
        count++;
        }
     }

      return count ;
    }
}
