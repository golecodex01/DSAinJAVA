class Solution {
    static long maxSubarraySum(int[] arr, int k) {

        int n = arr.length;
        long sum = 0;
        long max = 0;

        // first window
        for (int i = 0; i < k; i++) {
            sum += arr[i];
        }

        max = sum;

        // sliding window
        for (int i = k; i < n; i++) {
            sum += arr[i];
            sum -= arr[i - k];
            max = Math.max(max, sum);
        }

        return max;
    }
}
