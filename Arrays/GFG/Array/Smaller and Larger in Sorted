class Solution {
    int[] getMoreAndLess(int[] arr, int target) {
        // code here
      
        int first=0;
        int second=0;
        
        for(int i=0;i<arr.length;i++){
            if(arr[i]<=target){
                first++;
            }
            if(arr[i]>=target){
                second++;
            }
        }
       int []data = {first,second};
        return data;
    }
}
